{
  "name": "Flask Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "vivaxy.vscode-conventional-commits",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "forwardPorts": [5000],
  "remoteUser": "vscode"
}